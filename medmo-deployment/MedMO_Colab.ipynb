# @title 2. Load MedMO-4B Model
import torch
from transformers import Qwen3VLForConditionalGeneration, AutoProcessor
from qwen_vl_utils import process_vision_info

print("🔄 Loading MedMO-4B...")

# Check GPU
if torch.cuda.is_available():
    print(f"✅ GPU available: {torch.cuda.get_device_name(0)}")
    print(f"💾 GPU memory: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB")
else:
    print("⚠️ No GPU - will use CPU (slower)")

# Load model with 4-bit quantization to save memory
model_id = "MBZUAI/MedMO-4B"

model = Qwen3VLForConditionalGeneration.from_pretrained(
    model_id,
    torch_dtype=torch.bfloat16 if torch.cuda.is_available() else torch.float32,
    device_map="auto" if torch.cuda.is_available() else None,
    load_in_4bit=True if torch.cuda.is_available() else False,
    bnb_4bit_compute_dtype=torch.bfloat16 if torch.cuda.is_available() else None,
)

processor = AutoProcessor.from_pretrained(model_id)

print("✅ Model loaded successfully!")

# @title 3. Define Analysis Function
from PIL import Image
import io
import base64

def analyze_medical_image(image_input, prompt="Analyze this medical image", language="en"):
    """
    Analyze medical image using MedMO-4B
    
    Args:
        image_input: PIL Image or base64 string
        prompt: Analysis prompt
        language: 'en' or 'ar'
    """
    # Handle base64 input
    if isinstance(image_input, str) and image_input.startswith('data:image'):
        image_data = base64.b64decode(image_input.split(',')[1])
        image = Image.open(io.BytesIO(image_data)).convert('RGB')
    elif isinstance(image_input, str):
        image_data = base64.b64decode(image_input)
        image = Image.open(io.BytesIO(image_data)).convert('RGB')
    else:
        image = image_input
    
    # Add language instruction
    if language == "ar":
        prompt = f"باللغة العربية: {prompt}"
    
    # Prepare messages
    messages = [
        {
            "role": "user",
            "content": [
                {"type": "image", "image": image},
                {"type": "text", "text": prompt},
            ],
        }
    ]
    
    # Process
    text = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
    image_inputs, video_inputs = process_vision_info(messages)
    inputs = processor(
        text=[text],
        images=image_inputs,
        videos=video_inputs,
        padding=True,
        return_tensors="pt",
    )
    inputs = inputs.to(model.device)
    
    # Generate
    with torch.no_grad():
        generated_ids = model.generate(
            **inputs,
            max_new_tokens=512,
            do_sample=True,
            temperature=0.7,
            top_p=0.9
        )
    
    generated_ids_trimmed = [
        out_ids[len(in_ids):] for in_ids, out_ids in zip(inputs.input_ids, generated_ids)
    ]
    output_text = processor.batch_decode(
        generated_ids_trimmed,
        skip_special_tokens=True,
        clean_up_tokenization_spaces=False
    )[0]
    
    return output_text

# Test with sample
print("✅ Analysis function ready!")

# @title 4. Start API Server with ngrok
from fastapi import FastAPI, File, UploadFile, Form
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import uvicorn
from pyngrok import ngrok
import nest_asyncio

nest_asyncio.apply()

app = FastAPI(title="MedMO-4B API (Colab)")

# CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

class AnalysisRequest(BaseModel):
    image_base64: str
    prompt: str = "Analyze this medical image"
    language: str = "en"

@app.get("/health")
def health_check():
    return {
        "status": "healthy",
        "model": "MedMO-4B",
        "gpu": torch.cuda.is_available(),
        "gpu_name": torch.cuda.get_device_name(0) if torch.cuda.is_available() else None
    }

@app.post("/analyze")
async def analyze_image(
    file: UploadFile = File(...),
    prompt: str = Form("Analyze this medical image"),
    language: str = Form("en")
):
    from PIL import Image
    import io
    
    contents = await file.read()
    image = Image.open(io.BytesIO(contents)).convert('RGB')
    
    result = analyze_medical_image(image, prompt, language)
    
    return {
        "analysis": result,
        "model": "MedMO-4B",
        "language": language
    }

@app.post("/analyze/base64")
async def analyze_base64(request: AnalysisRequest):
    result = analyze_medical_image(request.image_base64, request.prompt, request.language)
    
    return {
        "analysis": result,
        "model": "MedMO-4B",
        "language": request.language
    }

# Start ngrok tunnel
print("🔄 Starting ngrok tunnel...")

# Get your free token from: https://dashboard.ngrok.com/get-started/your-authtoken
# Then uncomment and add your token:
# ngrok.set_auth_token("YOUR_NGROK_TOKEN_HERE")

public_url = ngrok.connect(8000)
print(f"🌐 Public URL: {public_url}")
print(f"📊 Health check: {public_url}/health")

# Start server
print("🚀 Starting server...")
uvicorn.run(app, host="0.0.0.0", port=8000)
